# Database (SQLite by default -- zero setup, file lives in prisma/dev.db)
# For production, swap to a hosted Postgres URL and change the provider
# in prisma/schema.prisma from "sqlite" to "postgresql".
DATABASE_URL="file:./dev.db"

# NextAuth
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Host / admin login credentials
# ADMIN_EMAIL is whatever email you want to log in with.
# ADMIN_PASSWORD_HASH is generated by running: npm run hash-password
# (it will prompt you for a plaintext password and print the bcrypt hash to paste here)
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD_HASH="replace-with-generated-bcrypt-hash"
