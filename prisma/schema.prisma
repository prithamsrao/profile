generator client {
  provider = "prisma-client-js"
}

datasource db {

  // SQLite for zero-friction local dev. Switch to "postgresql" for production
  // and point DATABASE_URL at your hosted database.


  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id        Int      @id @default(autoincrement())
  name      String   @default("Pritham S Rao")
  title     String   @default("Computer Science Student")
  bio       String   @default("Hey All!!, Welcome to my site..")
  location  String?
  email     String?
  github    String?
  linkedin  String?
  twitter   String?
  website   String?
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  summary     String
  description String
  coverImage  String?
  techStack   String
  repoUrl     String?
  demoUrl     String?
  articleUrl  String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Education {
  id          String   @id @default(cuid())
  institution String
  degree      String
  field       String?
  startDate   String
  endDate     String?
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Experience {
  id          String   @id @default(cuid())
  company     String
  role        String
  location    String?
  startDate   String
  endDate     String?
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Skill {
  id       String @id @default(cuid())
  category String
  name     String
  order    Int    @default(0)
}

model Recommendation {
  id        String   @id @default(cuid())
  name      String
  role      String
  quote     String
  photo     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}
